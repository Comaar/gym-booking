# TeamSystem / OndeChiare Configuration
TS_BASE_URL=https://inforyou.teamsystem.com/ondechiare
TS_COMPANY_ID=2
TS_LOGIN=your_username_here
TS_PASSWORD=your_password_here

# CRITICAL: iyesurl value from browser DevTools
# This is the BaseAddress that routes API requests to the correct tenant
TS_IYESURL=http://app.ondechiare.it:65432/

# TEMPORARY: app-token from browser (until we find how to generate it)
# Get this from: Chrome DevTools → Application → Cookies → app-token
# Copy the value and paste here
TS_APP_TOKEN=your_app_token_from_browser_here

# Timezone
APP_TIMEZONE=Europe/Rome

# HTTP Settings
HTTP_TIMEOUT_SECONDS=15
LOGIN_TIMEOUT_SECONDS=15

# Booking retry settings (network/transient errors only)
BOOKING_MAX_ATTEMPTS=3
BOOKING_RETRY_BACKOFF_SECONDS=1.5

# Cookie persistence
COOKIE_FILE=./session_cookies.json

# Logging
LOG_LEVEL=INFO
